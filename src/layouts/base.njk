<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{% if title %}{{ title }} · {% endif %}Cookbook</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link rel="stylesheet" href="{{ '/style.css' | url }}">
  <link rel="stylesheet" href="{{ '/print.css' | url }}" media="print">
</head>
<body>

  <header class="site-header">
    <div class="wrap header-wrap">
      <a class="brand" href="{{ '/' | url }}" aria-label="My Family Cookbook home">
        <span class="brand-icon" aria-hidden="true">
          <svg viewBox="0 0 32 32" focusable="false">
            <path d="M5 7.5c3.5-.8 6.9-.2 10 1.8v16.2c-3.1-2-6.5-2.6-10-1.8V7.5Z"/>
            <path d="M27 7.5c-3.5-.8-6.9-.2-10 1.8v16.2c3.1-2 6.5-2.6 10-1.8V7.5Z"/>
            <path d="M15 9.3h2M8 11.6c1.5-.1 3 .1 4.4.6M8 15c1.5-.1 3 .1 4.4.6M8 18.4c1.5-.1 3 .1 4.4.6M19.6 12.2c1.4-.5 2.9-.7 4.4-.6M19.6 15.6c1.4-.5 2.9-.7 4.4-.6M19.6 19c1.4-.5 2.9-.7 4.4-.6"/>
          </svg>
        </span>
        <span>My Family Cookbook</span>
      </a>

      <nav class="site-nav" aria-label="Primary">
        <a href="{{ '/' | url }}">Home</a>
        <a href="{{ '/recipes/' | url }}">All Recipes</a>
        <a href="{{ '/categories/' | url }}">Categories</a>
        <a href="{{ '/tags/' | url }}">Tags</a>
        <a href="{{ '/search/' | url }}">Search</a>
      </nav>

      <form class="header-search" action="{{ '/search/' | url }}" method="get" role="search">
        <label for="siteSearch" class="sr-only">Search recipes</label>
        <input id="siteSearch" name="q" type="search" placeholder="Search recipes...">
        <button type="submit" aria-label="Search">
          <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
            <circle cx="11" cy="11" r="7"></circle>
            <path d="m16.5 16.5 4 4"></path>
          </svg>
        </button>
      </form>
    </div>
  </header>

  <section class="cookbook-hero" aria-labelledby="cookbookHeroTitle">
    <div class="hero-art hero-art-left" aria-hidden="true">
      <img src="{{ '/images/cookbook-hero-left.png' | url }}" alt="">
    </div>
    <div class="wrap hero-content">
      <h1 id="cookbookHeroTitle">Welcome to My Family Cookbook</h1>
      <span class="flourish" aria-hidden="true"></span>
      <p>Explore a collection of family recipes passed down through generations and gathered along the way. Alongside them are favorites my father and I have collected over the years—each one worth sharing and, whenever possible, traced back to its original source.</p>
      <div class="hero-actions" aria-label="Cookbook links">
        <a class="button primary" href="{{ '/recipes/page/1/' | url }}">All Recipes</a>
        <a class="button secondary" href="{{ '/categories/' | url }}">Browse Categories</a>
        <a class="button secondary" href="{{ '/tags/' | url }}">Browse Tags</a>
      </div>
    </div>
    <div class="hero-art hero-art-right" aria-hidden="true">
      <img src="{{ '/images/cookbook-hero-right.png' | url }}" alt="">
    </div>
  </section>

  <main id="main" class="site-main">
    <div class="wrap">
      {{ content | safe }}
    </div>
  </main>

  <footer class="site-footer">
    <div class="wrap">
      <p>&copy; {{ "" | year }} My Family Cookbook</p>
      <p>
        <a href="{{ '/' | url }}">Home</a> ·
        <a href="{{ '/recipes/' | url }}">All Recipes</a> ·
        <a href="{{ '/categories/' | url }}">Categories</a> ·
        <a href="{{ '/tags/' | url }}">Tags</a> ·
        <a href="{{ '/search/' | url }}">Search</a>
      </p>
    </div>
  </footer>
</body>
</html>



